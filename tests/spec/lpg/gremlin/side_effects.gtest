# Gremlin Side-Effect Steps: aggregate, store, sack, cap, sideEffect
#
# Covers: aggregate(), store() (legacy alias), sack() for state,
# cap() for materializing, sideEffect() for inline operations.
#
# Social network topology (from dataset):
#   Persons: Alix(30, Amsterdam), Gus(25, Berlin), Vincent(35, Paris)
#   Company: Grafeo OSS (founded 2025)
#   Edges: Alix-KNOWS->Gus, Gus-KNOWS->Vincent, Alix-WORKS_AT->Grafeo OSS

meta:
  language: gremlin
  model: lpg
  section: "side-effects"
  title: Side-effect steps
  dataset: social_network

tests:

  # ---------------------------------------------------------------------------
  # aggregate() - collect into a side-effect list
  # ---------------------------------------------------------------------------

  - name: aggregate_basic
    skip: "sack/aggregate/store not implemented"
    query: |
      g.V().has('Person', 'name', 'Alix')
        .out('KNOWS')
        .aggregate('friends')
        .out('KNOWS')
        .aggregate('friends')
        .cap('friends')
    expect:
      count: 1

  - name: aggregate_then_filter
    skip: "sack/aggregate/store not implemented"
    query: |
      g.V().hasLabel('Person')
        .aggregate('all_people')
        .out('KNOWS')
        .where(without('all_people'))
        .values('name')
    expect:
      empty: true

  - name: aggregate_with_by
    skip: "sack/aggregate/store not implemented"
    query: |
      g.V().hasLabel('Person')
        .aggregate('names').by('name')
        .cap('names')
    expect:
      count: 1

  # ---------------------------------------------------------------------------
  # store() - lazy aggregate (legacy alias)
  # ---------------------------------------------------------------------------

  - name: store_basic
    skip: "sack/aggregate/store not implemented"
    query: |
      g.V().has('Person', 'name', 'Alix')
        .store('visited')
        .out()
        .store('visited')
        .cap('visited')
    expect:
      count: 1

  # ---------------------------------------------------------------------------
  # sack() - per-traverser state
  # ---------------------------------------------------------------------------

  - name: sack_initial_value
    skip: "sack/aggregate/store not implemented"
    query: |
      g.withSack(0)
        .V().hasLabel('Person')
        .sack()
    expect:
      count: 3

  - name: sack_sum_ages
    skip: "sack/aggregate/store not implemented"
    query: |
      g.withSack(0)
        .V().hasLabel('Person')
        .sack(sum).by('age')
        .sack()
    expect:
      count: 3

  - name: sack_accumulate_through_path
    skip: "sack/aggregate/store not implemented"
    query: |
      g.withSack(0)
        .V().has('Person', 'name', 'Alix')
        .sack(sum).by('age')
        .out('KNOWS')
        .sack(sum).by('age')
        .sack()
    expect:
      rows:
        - [55]

  - name: sack_multiply
    skip: "sack/aggregate/store not implemented"
    query: |
      g.withSack(1.0)
        .V().has('Person', 'name', 'Alix')
        .out('KNOWS')
        .out('KNOWS')
        .sack()
    expect:
      rows:
        - [1.0]

  # ---------------------------------------------------------------------------
  # cap() - materialize side-effect
  # ---------------------------------------------------------------------------

  - name: cap_group_count
    skip: "sack/aggregate/store not implemented"
    query: |
      g.V().hasLabel('Person')
        .groupCount('cities').by('city')
        .cap('cities')
    expect:
      count: 1

  - name: cap_multiple_keys
    skip: "sack/aggregate/store not implemented"
    query: |
      g.V().hasLabel('Person')
        .groupCount('by_city').by('city')
        .groupCount('by_age').by('age')
        .cap('by_city', 'by_age')
    expect:
      count: 1

  # ---------------------------------------------------------------------------
  # sideEffect() - inline operations
  # ---------------------------------------------------------------------------

  - name: side_effect_passthrough
    skip: "sack/aggregate/store not implemented"
    query: |
      g.V().has('Person', 'name', 'Alix')
        .sideEffect(outE().count())
        .values('name')
    expect:
      rows:
        - [Alix]

  - name: side_effect_does_not_alter_traversal
    skip: "sack/aggregate/store not implemented"
    query: |
      g.V().hasLabel('Person')
        .sideEffect(out('KNOWS'))
        .count()
    expect:
      rows:
        - [3]

  # ---------------------------------------------------------------------------
  # Real-world: accumulate latency across dependency chain
  # ---------------------------------------------------------------------------

  - name: sack_latency_chain
    skip: "sack/aggregate/store not implemented"
    setup:
      - "INSERT (:Service {name: 'frontend', latency: 10})"
      - "INSERT (:Service {name: 'backend', latency: 20})"
      - "INSERT (:Service {name: 'database', latency: 5})"
      - "MATCH (a:Service {name: 'frontend'}), (b:Service {name: 'backend'}) INSERT (a)-[:CALLS]->(b)"
      - "MATCH (a:Service {name: 'backend'}), (b:Service {name: 'database'}) INSERT (a)-[:CALLS]->(b)"
    query: |
      g.withSack(0)
        .V().has('Service', 'name', 'frontend')
        .sack(sum).by('latency')
        .out('CALLS')
        .sack(sum).by('latency')
        .out('CALLS')
        .sack(sum).by('latency')
        .sack()
    expect:
      rows:
        - [35]
